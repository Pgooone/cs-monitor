/**
 * Auth Store — 登录状态管理（已封存，保留接口兼容）
 *
 * 登录功能已移除，此 store 保留以避免其他模块引用报错。
 * 如需重新启用登录，从 archived/auth.store.ts 恢复。
 */

import { ref, computed } from 'vue'
import { defineStore } from 'pinia'

export const useAuthStore = defineStore('auth', () => {
  const token = ref<string | null>(null)
  const username = ref<string>('admin')
  const isLoading = ref(false)
  const error = ref<string | null>(null)
  const requiresPasswordChange = ref(false)
  const isLoggedIn = computed(() => true) // 始终视为已登录

  function login() { return { success: true, requiresPasswordChange: false } }
  function fetchMe() {}
  function changePassword() { return { success: true } }
  function logout() {}
  function initFromStorage() {}

  return {
    token, username, isLoading, error, requiresPasswordChange, isLoggedIn,
    login, fetchMe, changePassword, logout, initFromStorage,
  }
})
